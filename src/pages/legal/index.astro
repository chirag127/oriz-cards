---
import BaseLayout from '~/layouts/BaseLayout.astro'

const sections = [
  {
    slug: 'privacy',
    label: 'Privacy policy',
    desc: "What we collect, what we don't, your rights.",
  },
  { slug: 'terms', label: 'Terms of use', desc: 'The rules for using cards.oriz.in.' },
  { slug: 'disclaimer', label: 'Disclaimer', desc: 'Not financial / legal / tax advice.' },
  { slug: 'cookies', label: 'Cookie policy', desc: 'What cookies and localStorage we set.' },
  { slug: 'grievance', label: 'Grievance officer', desc: 'Mandatory contact under IT Rules 2021.' },
]
---

<BaseLayout
  title="Legal — oriz · cards"
  description="Privacy, terms, and grievance contact for cards.oriz.in."
>
  <div class="spine-prose">
    <header class="page-head">
      <p class="eyebrow mono"><a href="/">cards</a> / legal</p>
      <h1>legal</h1>
    </header>

    <section class="legal-list">
      <ul>
        {
          sections.map((s) => (
            <li>
              <a href={`/legal/${s.slug}/`} class="row">
                <h2>{s.label}</h2>
                <p>{s.desc}</p>
                <span class="arrow mono" aria-hidden="true">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .legal-list {
    padding-block: 2rem 4rem;
  }
  .legal-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .legal-list li + li .row {
    border-top: 0;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.125rem 1rem;
    border: 1px solid var(--rule);
    color: var(--ink);
    text-decoration: none;
    background: var(--paper-raised);
  }
  .row:hover {
    border-color: var(--accent);
  }
  .row h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    margin: 0 0 0.25rem;
    color: var(--ink);
  }
  .row p {
    color: var(--ink-mute);
    font-size: 0.875rem;
    margin: 0;
  }
  .arrow {
    color: var(--ink-mute);
    font-size: 1rem;
  }
  .row:hover .arrow {
    color: var(--accent);
  }
</style>
