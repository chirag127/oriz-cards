---
import AccountPanel from '~/components/AccountPanel.tsx'
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout
  title={`Account — oriz · cards`}
  description="Sign in to oriz. One account works across every oriz site."
  noindex={true}
>
  <div class="spine-prose">
    <header class="page-head">
      <p class="eyebrow mono"><a href="/">cards</a> / account</p>
      <h1>account</h1>
      <p class="lede">
        One sign-in works across every oriz site. Saved cards, comparisons,
        and your name embossed on every card preview follow you.
      </p>
    </header>

    <section>
      <AccountPanel client:load siteName="oriz / cards" />
    </section>
  </div>
</BaseLayout>
