---
import ContactForm from '~/components/ContactForm.tsx'
import BaseLayout from '~/layouts/BaseLayout.astro'

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="Contact — oriz · cards"
  description="Get in touch about cards.oriz.in — wrong fees, broken links, missing cards, bug reports."
>
  <div class="spine-prose">
    <header class="page-head">
      <p class="eyebrow mono"><a href="/">cards</a> / contact</p>
      <h1>contact</h1>
    </header>

    <section class="prose">
      <p class="lede">
        Spotted a wrong fee on a card page, an outdated rewards rate, or a card
        we missed? Drop a note. The fastest way to reach me is email:
        <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
      </p>
      <p>
        For anything site-related — typo, broken link, suggestion — use the
        form below. It posts to Web3Forms which forwards to my inbox. No data
        is stored on this site.
      </p>

      <ContactForm client:visible web3formsKey={web3formsKey} fromName="oriz · cards contact form" />

      <p>
        For privacy questions or DMCA notices, see the
        <a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
      </p>
    </section>
  </div>
</BaseLayout>
