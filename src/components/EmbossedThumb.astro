---
/*
 * EmbossedThumb — Astro-static 140×88 embossed-card thumbnail used in the
 * home ledger rows and the compare drawer. NO React island — these render
 * at build time as pure HTML/CSS, because the cardholder name is always
 * redacted in the thumbnail variant per the spec ("name redacted to dots
 * in list rows"). Only the hero needs a React island for the live
 * Firebase displayName.
 *
 * Component CSS is shared with EmbossedCard.tsx — those styles are scoped
 * to .emboss-thumb under EmbossedCard's <style>. Here we just emit the
 * markup with the same class names. Astro's bundler strips the duplicate
 * style declarations because the React component's <style> is deferred
 * (it only mounts where the island mounts), so we re-declare the static
 * CSS once in a single global block at the bottom for the static
 * thumbnails.
 */

interface Props {
  bankCode: string
  bankName: string
  network: string
  binPrefix?: string
  stock?: [string, string]
}

const NETWORK_LABEL: Record<string, string> = {
  Visa: 'VISA',
  Mastercard: 'MASTERCARD',
  RuPay: 'RuPay',
  Amex: 'AMEX',
  DinersClub: 'DINERS',
  Discover: 'DISCOVER',
}

const { bankCode, bankName, network, binPrefix = '4242', stock } = Astro.props as Props
const stockA = stock?.[0] ?? '#2B3A55'
const stockB = stock?.[1] ?? '#1A2438'
const networkLabel = NETWORK_LABEL[network] ?? network.toUpperCase()
const issuerLabel = (bankCode ?? bankName).toUpperCase()
const redactedName = '•••• •••• ••••'
---

<div
  class="emboss-static emboss-thumb-static"
  style={`--card-stock-a: ${stockA}; --card-stock-b: ${stockB};`}
  aria-hidden="true"
>
  <span class="emboss-issuer">{issuerLabel}</span>
  <span class="emboss-chip">
    <span class="emboss-chip-line"></span>
    <span class="emboss-chip-line"></span>
    <span class="emboss-chip-line"></span>
    <span class="emboss-chip-line"></span>
    <span class="emboss-chip-line"></span>
  </span>
  <span class="emboss-bin">{binPrefix} •••• •••• ••••</span>
  <span class="emboss-name">{redactedName}</span>
  <span class="emboss-network">{networkLabel}</span>
</div>

<style is:global>
  /* Shared static CSS for thumbnails. Scoped by .emboss-thumb-static so it
     never collides with the React-island variant. */
  .emboss-thumb-static {
    position: relative;
    width: 140px;
    height: 88px;
    border-radius: 6px;
    background: radial-gradient(120% 80% at 0% 0%, color-mix(in oklab, var(--card-stock-a) 90%, white) 0%, var(--card-stock-a) 35%, var(--card-stock-b) 100%);
    color: rgba(255, 255, 255, 0.88);
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.04em;
    overflow: hidden;
    isolation: isolate;
    flex-shrink: 0;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.08) inset,
      0 0 0 1px rgba(0, 0, 0, 0.25),
      0 4px 8px rgba(0, 0, 0, 0.2);
  }
  .emboss-thumb-static::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12) 0%, transparent 30%, transparent 70%, rgba(0, 0, 0, 0.18) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .emboss-thumb-static .emboss-issuer,
  .emboss-thumb-static .emboss-bin,
  .emboss-thumb-static .emboss-name,
  .emboss-thumb-static .emboss-network {
    position: absolute;
    z-index: 2;
    color: rgba(255, 255, 255, 0.9);
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.22),
      0 -1px 0 rgba(0, 0, 0, 0.5);
    transform: translateZ(0);
    font-feature-settings: 'tnum' 1, 'zero' 1, 'calt' 0;
  }
  .emboss-thumb-static .emboss-issuer {
    top: 6px;
    left: 8px;
    right: 8px;
    font-size: 7px;
    letter-spacing: 0.12em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .emboss-thumb-static .emboss-chip {
    position: absolute;
    top: 32%;
    left: 8px;
    width: 14px;
    height: 11px;
    z-index: 2;
    background: linear-gradient(135deg, #ecd28a 0%, #d4ae5c 30%, #b8923a 60%, #8b6e2a 100%);
    border-radius: 2px;
    display: grid;
    grid-template-rows: repeat(5, 1fr);
    padding: 1px;
    gap: 1px;
    box-shadow:
      0 0 0 0.5px rgba(0, 0, 0, 0.4),
      inset 0 0 0 0.5px rgba(255, 255, 255, 0.1);
  }
  .emboss-thumb-static .emboss-chip-line {
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.3));
    height: 0.5px;
    align-self: end;
  }
  .emboss-thumb-static .emboss-bin {
    left: 8px;
    top: calc(32% + 16px);
    font-size: 8px;
    letter-spacing: 0.06em;
  }
  .emboss-thumb-static .emboss-name {
    left: 8px;
    bottom: 8px;
    font-size: 7px;
    letter-spacing: 0.08em;
  }
  .emboss-thumb-static .emboss-network {
    right: 8px;
    bottom: 8px;
    font-size: 7px;
    letter-spacing: 0.12em;
  }
</style>
