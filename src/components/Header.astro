---
import HeaderControls from '~/components/HeaderControls.tsx'
import { FAMILY, FAMILY_SITES } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'
---

<header class="site-header">
  <div class="container-page header-inner">
    <a href={FAMILY.rootOrigin} class="brand" aria-label={`${FAMILY.brand} — back to hub`}>
      <span class="brand-mark">{FAMILY.brand}</span>
      <span class="brand-dot">.</span>
      <span class="brand-badge" aria-hidden="true">💳 {SITE_CONFIG.name}</span>
    </a>

    <nav aria-label="Primary" class="primary-nav">
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>

    <HeaderControls client:idle sites={FAMILY_SITES} siteName={SITE_CONFIG.name} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    height: 64px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-fg);
    line-height: 1;
  }
  .brand-dot { color: var(--color-accent); }
  .brand-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.5rem;
    padding: 0.25rem 0.5rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-fg-muted);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
  }
  .primary-nav {
    display: none;
    gap: 1.25rem;
    flex: 1;
    font-size: 0.9375rem;
  }
  .primary-nav a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .primary-nav a:hover { color: var(--color-fg); }
  @media (min-width: 768px) {
    .primary-nav { display: flex; }
  }
</style>
