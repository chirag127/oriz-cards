---
/*
 * Header — 56px slate-on-slate-deep terminal bar. NO mega-nav, NO dropdowns.
 * Left: brass-chip wordmark. Right: ⌘K hint, theme indicator, sign in.
 *
 * The filter rail on the home page IS the navigation — there is no dropdown
 * menu of categories. The header is intentionally sparse: a Bloomberg
 * terminal does not have hamburger menus.
 */
import Wordmark from '~/components/Wordmark.astro'
---

<header class="header">
  <div class="spine header-row">
    <Wordmark href="/" size={18} />
    <nav class="header-nav" aria-label="Primary">
      <a href="/about/" class="nav-link mono">about</a>
      <a href="/contact/" class="nav-link mono">contact</a>
    </nav>
    <div class="header-controls">
      <kbd class="kbd mono" title="Filter rail focus is search on this site">⌘K</kbd>
      <span class="theme-hint mono" aria-hidden="true">◐</span>
      <a href="/account/" class="sign-in">sign in</a>
    </div>
  </div>
  <hr class="hairline" />
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--paper-deep);
    color: var(--ink);
  }
  .header-row {
    display: flex;
    align-items: center;
    height: 56px;
    gap: 1.25rem;
  }
  .header-nav {
    display: none;
    flex: 1;
    gap: 1.25rem;
  }
  .nav-link {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
  }
  .nav-link:hover {
    color: var(--accent);
  }
  .header-controls {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
  }
  .kbd {
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding-inline: 0.5rem;
    background: var(--paper);
    border: 1px solid var(--rule);
    color: var(--ink-mute);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .theme-hint {
    color: var(--ink-mute);
    font-size: 14px;
    cursor: default;
  }
  .sign-in {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: lowercase;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    text-decoration-color: var(--ink-mute);
    letter-spacing: 0.04em;
  }
  .sign-in:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
  .sign-in:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    text-decoration-color: var(--accent);
  }
  @media (min-width: 768px) {
    .header-nav {
      display: inline-flex;
      margin-left: 1rem;
    }
  }
</style>
