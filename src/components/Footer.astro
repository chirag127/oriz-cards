---
import { AdSlot, NewsletterCta, FAMILY, FAMILY_SITES } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'

const year = new Date().getFullYear()
const buttondown = import.meta.env.PUBLIC_BUTTONDOWN_USERNAME
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const adsenseFooterSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_FOOTER
---

<footer class="site-footer">
  {adsenseClient && adsenseFooterSlot && (
    <div class="container-page footer-ad">
      <AdSlot client:visible client={adsenseClient} slotId={adsenseFooterSlot} format="horizontal" />
    </div>
  )}

  {buttondown && (
    <div class="container-page footer-newsletter">
      <NewsletterCta client:visible buttondownUsername={buttondown} />
    </div>
  )}

  <div class="container-page footer-inner">
    <div class="footer-col">
      <p class="footer-brand">{SITE_CONFIG.name}</p>
      <p class="footer-tag">
        {SITE_CONFIG.tagline}. Part of the
        <a href={FAMILY.rootOrigin}>{FAMILY.brand}</a> family by
        <a href="/about/">{FAMILY.operator.name}</a>.
      </p>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Family</h2>
      <ul class="footer-links">
        {FAMILY_SITES.map((s) => (
          <li><a href={s.url}><span aria-hidden="true">{s.emoji}</span> {s.name}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Site</h2>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/account/">Account</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Legal</h2>
      <ul class="footer-links">
        <li><a href="/legal/privacy/">Privacy</a></li>
        <li><a href="/legal/terms/">Terms</a></li>
        <li><a href="/legal/disclaimer/">Disclaimer</a></li>
        <li><a href="/legal/cookies/">Cookies</a></li>
        <li><a href="/legal/grievance/">Grievance officer</a></li>
      </ul>
    </div>
  </div>

  <div class="container-page footer-bottom">
    <p>&copy; {year} {FAMILY.operator.name}. Built with <a href={`https://github.com/${FAMILY.operator.githubHandle}/oriz`}>oriz</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding-block: 3rem 1.5rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-soft);
  }
  .footer-ad { margin-bottom: 2.5rem; }
  .footer-newsletter { margin-bottom: 2.5rem; }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px) { .footer-inner { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .footer-inner { grid-template-columns: 2fr 1fr 1fr 1fr; } }
  .footer-brand {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .footer-tag { color: var(--color-fg-muted); margin: 0; max-width: 36ch; }
  .footer-h {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    margin: 0 0 0.75rem;
  }
  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-links a { color: var(--color-fg-muted); text-decoration: none; font-size: 0.9375rem; }
  .footer-links a:hover { color: var(--color-fg); }
  .footer-bottom {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-fg-soft);
    font-size: 0.8125rem;
  }
  .footer-bottom p { margin: 0; }
</style>
