---
/*
 * Footer — the statement-stub. Brass hairline above + 4-column grid set
 * entirely in 12px Inter Tight Mute. Below the grid: a single mono line
 * `750 cards · last refreshed <date> · {git short-sha}`.
 *
 * NO social icons. NO newsletter form. NO trusted-by logos. Just data and
 * legal — exactly like the back of a credit-card statement.
 *
 * Family-anchor parity: PUBLIC_DEPLOY_TIME + PUBLIC_GIT_SHA wiring matches
 * oriz-home. Falls back to build-time `new Date()` and 'dev'.
 */
import { FAMILY_SITES } from '~/lib/family'

const otherSites = FAMILY_SITES.filter((s) => s.slug !== 'cards')

const deployTimeRaw = import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString().slice(0, 10)
const deployDate = deployTimeRaw.slice(0, 10)
const gitSha = import.meta.env.PUBLIC_GIT_SHA ?? 'dev'
const cardCount = 750
---

<footer class="footer">
  <hr class="hairline-brass" />
  <div class="spine footer-grid">
    <div class="col">
      <h2 class="col-h mono">family</h2>
      <ul>
        {
          otherSites.map((s) => (
            <li>
              <a href={s.url}>{s.name.toLowerCase()}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="col">
      <h2 class="col-h mono">data</h2>
      <ul>
        <li><a href="/about/#methodology">methodology</a></li>
        <li><a href="/about/#sources">sources (RBI, MITC, KFS)</a></li>
        <li><a href="/about/#licence">licence (CC BY 4.0)</a></li>
        <li><a href="/cards.json">download as JSON</a></li>
      </ul>
    </div>

    <div class="col">
      <h2 class="col-h mono">legal</h2>
      <ul>
        <li><a href="/legal/privacy/">privacy</a></li>
        <li><a href="/legal/terms/">terms</a></li>
        <li><a href="/legal/disclaimer/">disclaimer</a></li>
        <li><a href="/legal/cookies/">cookies</a></li>
        <li><a href="/legal/grievance/">grievance officer</a></li>
        <li><a href="/contact/">contact</a></li>
      </ul>
    </div>

    <div class="col">
      <h2 class="col-h mono">colophon</h2>
      <p class="col-note">
        Built in Bhubaneswar. Numbers in JetBrains Mono. No card data is sold.
      </p>
    </div>
  </div>
  <hr class="hairline" />
  <div class="spine colophon">
    <p class="colophon-line mono">
      {cardCount} cards · last refreshed <time datetime={deployDate}>{deployDate}</time> ·
      <code>{gitSha}</code>
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 5rem;
    background: var(--paper-deep);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    padding-block: 2rem 1.75rem;
  }
  .col {
    padding-inline: 1rem;
    border-right: 1px solid var(--rule);
  }
  .col:first-child {
    padding-left: 0;
  }
  .col:last-child {
    border-right: 0;
    padding-right: 0;
  }
  .col-h {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
    font-weight: 500;
    margin: 0 0 0.875rem;
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'calt' 0;
  }
  .col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .col a {
    color: var(--ink-mute);
    font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1.4;
    text-decoration: none;
  }
  .col a:hover {
    color: var(--accent);
  }
  .col a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .col-note {
    margin: 0;
    color: var(--ink-mute);
    font-size: 12px;
    line-height: 1.5;
    max-width: 22ch;
  }

  .colophon {
    padding-block: 1.25rem 2rem;
  }
  .colophon-line {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-mute);
    line-height: 1.6;
    letter-spacing: 0.04em;
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'calt' 0;
  }
  .colophon code {
    font-family: var(--font-mono);
    color: var(--ink);
    background: transparent;
    padding: 0;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 1.75rem;
    }
    .col:nth-child(2n) {
      border-right: 0;
      padding-right: 0;
    }
    .col:nth-child(2n + 1) {
      padding-left: 0;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .col {
      border-right: 0;
      padding: 0;
    }
  }
</style>
