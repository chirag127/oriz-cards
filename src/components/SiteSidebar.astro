---
/**
 * SiteSidebar — wraps the oriz-ui Sidebar with cards.oriz.in's link sections.
 * Sections: Credit / Debit / Prepaid / Compare / By bank — plus the family
 * quick-jump at the bottom.
 */
import { Sidebar, FAMILY_SITES } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'

interface Props {
  activeSection?: string
}

const { activeSection } = Astro.props as Props

const sections = [
  {
    title: 'Cards',
    links: [
      { label: 'Credit', href: '/credit/', active: activeSection === 'credit' },
      { label: 'Debit', href: '/debit/', active: activeSection === 'debit' },
      { label: 'Prepaid', href: '/prepaid/', active: activeSection === 'prepaid' },
    ],
  },
  {
    title: 'Tools',
    links: [
      { label: 'Compare', href: '/compare/', active: activeSection === 'compare' },
      { label: 'By bank', href: '/banks/', active: activeSection === 'banks' },
    ],
  },
  {
    title: 'Site',
    links: [
      { label: 'About', href: '/about/', active: activeSection === 'about' },
      { label: 'Contact', href: '/contact/', active: activeSection === 'contact' },
      { label: 'Account', href: '/account/', active: activeSection === 'account' },
    ],
  },
  {
    title: 'Family',
    links: FAMILY_SITES.filter((s) => s.slug !== SITE_CONFIG.slug).map((s) => ({
      label: `${s.emoji} ${s.name}`,
      href: s.url,
    })),
  },
]
---

<Sidebar
  client:idle
  siteName={SITE_CONFIG.name}
  siteSlug={SITE_CONFIG.slug}
  sections={sections}
/>
